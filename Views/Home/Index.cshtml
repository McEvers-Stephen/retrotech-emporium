@{
    ViewData["Title"] = "Home Page";
    Layout = "_Layout";
}

<section class="hero-section text-center">
    <div class="container py-5">
        <p class="hero-kicker">RETRO • MODERN • COLLECTIBLE</p>

        <h1 class="hero-title">
            RetroTech Emporium
        </h1>

        <p class="hero-subtitle">
            Yesterday's technology. Tomorrow's inspiration.
        </p>

        <div class="mt-4 d-flex justify-content-center gap-3 flex-wrap">
            <a asp-controller="Products" asp-action="Index" class="btn btn-retro">
                Browse Collection
            </a>

            <a asp-controller="Home" asp-action="CompareEras" class="btn btn-outline-retro">
                Compare Eras
            </a>
        </div>
    </div>
</section>
<section class="era-section py-5">
    <div class="container">
        <h2 class="section-title text-center mb-5">Browse by Era</h2>

        <div class="row g-4">
            <div class="col-md-4 scroll-card">
                <div class="era-card">
                    <div class="era-icon">🖥️</div>
                    <h3>1970s–1980s</h3>
                    <p>The birth of personal computing.</p>
                </div>
            </div>

            <div class="col-md-4 scroll-card">
                <div class="era-card">
                    <div class="era-icon">📼</div>
                    <h3>1990s–2000s</h3>
                    <p>Gaming, media, and the internet revolution.</p>
                </div>
            </div>

            <div class="col-md-4 scroll-card">
                <div class="era-card">
                    <div class="era-icon">📱</div>
                    <h3>Today</h3>
                    <p>Devices inspired by decades of innovation.</p>
                </div>
            </div>
        </div>
    </div>
</section>
