
@{
    Layout = "_Layout";
}

@model Product

<section class="py-5">
    <div class="container">
        <div class="product-detail-card">
            <div class="product-era">@Model.yearReleased</div>

            <h1>@Model.productName</h1>

            <p class="detail-category">@Model.Category?.Name</p>

            <p class="detail-description">
                @Model.productDescription
            </p>

            <div class="detail-price">
                @Model.productPrice.ToString("C")
            </div>

            <p class="detail-stock">
                In Stock: @Model.quantityInStock
            </p>

            <a asp-controller="Products" asp-action="Index" class="btn btn-outline-retro mt-4">
                Back to Shop
            </a>
        </div>
    </div>
</section>
