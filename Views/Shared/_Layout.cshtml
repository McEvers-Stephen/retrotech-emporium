<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    @addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Retrotech Emporium</title>
    <script type="importmap"></script>

    <link rel="stylesheet" href="/css/site.css" />

</head>

    <body class="bg-gray-950 text-white">
        
    <h1 style="color:red;">LAYOUT IS LOADING</h1>
    <header class="bg-gray-900 text-white border-b border-cyan-500/30">
        <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">

            <!-- Logo -->
            <a href="/" class="text-2xl font-bold tracking-wide text-cyan-400 hover:text-cyan-300">
                RetroTech Emporium
            </a>

            <!-- Nav -->
            <nav class="flex gap-6 text-sm uppercase tracking-widest">

                <a href="/" class="hover:text-cyan-400 transition">
                    Home
                </a>

                <a href="/Products" class="hover:text-cyan-400 transition">
                    Products
                </a>

                <a href="/Home/CompareEras" class="hover:text-cyan-400 transition">
                    Compare Eras
                </a>

                <a href="/Home/About" class="hover:text-cyan-400 transition">
                    About
                </a>

            </nav>

            <!-- Right side (future cart/user area) -->
            <div class="text-xs text-gray-400">
                Beta Build
            </div>

        </div>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Retrotech Emporium - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
