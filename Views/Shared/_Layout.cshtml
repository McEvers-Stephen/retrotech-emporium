<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    @addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Retrotech Emporium</title>
    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

</head>

    <body class="bg-gray-950 text-white">

    <header class="retro-header sticky-top">
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container">
                <a class="navbar-brand retro-logo" asp-controller="Home" asp-action="Index">
                    RetroTech Emporium
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-3">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Products" asp-action="Index">Shop</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="CompareEras">Compare Eras</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="About">About</a>
                        </li>
                        <li class="nav-item ms-lg-3">
                            <span class="retro-status">
                                <span class="status-dot"></span>
                                COLLECTION: BUILDING
                            </span>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top retro-logo footer text-muted text-center">
        <div class="container-footer">
            &copy; 2026 - Retrotech Emporium - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        const scrollCards = document.querySelectorAll('.scroll-card');

        const cardObserver = new IntersectionObserver(entries => {
        entries.forEach(entry => {
        if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        } else {
        entry.target.classList.remove('visible');
        }
        });
        }, {
        threshold: 0.2
        });

        scrollCards.forEach(card => {
        cardObserver.observe(card);
        });
    </script>
</body>
</html>
